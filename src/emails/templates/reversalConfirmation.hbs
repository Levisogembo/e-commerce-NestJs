<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto;">
  <h1 style="color: #4caf50;">Reversal Confirmed</h1>
  <p>Your request for order reversal was processed successfully.</p>

  {{#if data}}
    {{#with data}}
      <div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 20px 0;">
        <h3 style="margin-top: 0;">Reversal Details</h3>
        <p><strong>Order ID:</strong> {{orderId}}</p>
        {{#if name}}<p><strong>Customer:</strong> {{name}}</p>{{/if}}
        <p><strong>Date:</strong> {{date}}</p>
        <p><strong>Refund Total:</strong> ${{refundAmount}}</p>
      </div>
    {{/with}}
  {{else}}
    <div style="background: #f5f5f5; padding: 15px; border-radius: 8px; margin: 20px 0;">
      <h3 style="margin-top: 0;">Order Details</h3>
      <p><strong>Order ID:</strong> {{orderId}}</p>
      {{#if transactionId}}<p><strong>Transaction ID:</strong> {{transactionId}}</p>{{/if}}
      <p><strong>Date:</strong> {{date}}</p>
      <p><strong>Total:</strong> ${{total}}</p>
    </div>

   
  {{/if}}

  <p style="margin-top: 20px;">Thank you for shopping with us.</p>
</div>